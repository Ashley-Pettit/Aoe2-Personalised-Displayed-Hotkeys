# ---------------------------------------------------------------------------
# VK codes / .hkp parser / image tools (same as before, compacted)
# ---------------------------------------------------------------------------
VK = {0x08:"Bksp",0x09:"Tab",0x0D:"Enter",0x1B:"Esc",0x20:"Spc",0x21:"PgUp",0x22:"PgDn",
      0x23:"End",0x24:"Home",0x25:"Left",0x26:"Up",0x27:"Right",0x28:"Down",0x2D:"Ins",
      0x2E:"Del",0xC0:"`",0xBD:"-",0xBB:"=",0xDB:"[",0xDD:"]",0xDC:"\\",0xBA:";",
      0xDE:"'",0xBC:",",0xBE:".",0xBF:"/",0x00:""}
for c in range(0x30,0x3A): VK[c]=chr(c)
for c in range(0x41,0x5B): VK[c]=chr(c)
for c in range(0x70,0x7C): VK[c]="F"+str(c-0x6F)
for c in range(0x60,0x6A): VK[c]="N"+str(c-0x60)

def key_name(code): return VK.get(code,"0x%02X"%code)

def parse_hkp(path):
    data=zlib.decompress(open(path,"rb").read(),-15); out={}; pos=0
    while True:
        g=data.find(b"GroupHeaderGuard",pos)
        if g<0: break
        s=g+len("GroupHeaderGuard"); e=data.find(b"HandlerBaseGroupEnd",s)
        if e<0: break
        p=data[s:e]; pos=e+len("HandlerBaseGroupEnd")
        if len(p)<12: continue
        key,hid=struct.unpack("<ii",p[:8])
        if key==0: out[hid]=""
        else:
            mods=[]
            if p[8]&1: mods.append("Ctrl")
            if p[9]&1: mods.append("Alt")
            if p[10]&1: mods.append("Shift")
            out[hid]="+".join(mods+[key_name(key)])
    return out

def validate_hkp(path):
    """Returns (ok, num_bindings) or raises."""
    try:
        binds = parse_hkp(path)
        bound = sum(1 for v in binds.values() if v)
        return len(binds) > 50, bound
    except Exception:
        return False, 0

def _font(size):
    for name in ["arialbd.ttf","arial.ttf","seguisb.ttf",
                 "DejaVuSans-Bold.ttf","LiberationSans-Bold.ttf"]:
        for path in [os.path.join(os.environ.get("WINDIR",r"C:\Windows"),"Fonts",name),
                     "/usr/share/fonts/truetype/dejavu/"+name,
                     "/usr/share/fonts/truetype/liberation/"+name,name]:
            try: return ImageFont.truetype(path,size)
            except: pass
    return ImageFont.load_default()

def read_image(path):
    im=Image.open(path); im.load(); return im.convert("RGBA")

def _dds_header(w,h):
    b=bytearray(128); b[0:4]=b"DDS "
    struct.pack_into("<I",b,4,124)
    struct.pack_into("<I",b,8,0x1|0x2|0x4|0x1000|0x8)
    struct.pack_into("<i",b,12,h); struct.pack_into("<i",b,16,w)
    struct.pack_into("<I",b,20,w*4); struct.pack_into("<I",b,28,1)
    struct.pack_into("<I",b,76,32); struct.pack_into("<I",b,80,0x1|0x40)
    struct.pack_into("<I",b,88,32); struct.pack_into("<I",b,92,0xFF)
    struct.pack_into("<I",b,96,0xFF00); struct.pack_into("<I",b,100,0xFF0000)
    struct.pack_into("<I",b,104,0xFF000000); struct.pack_into("<I",b,108,0x1000)
    return bytes(b)

def write_baked(img,out_path):
    d=os.path.dirname(out_path)
    if d: os.makedirs(d,exist_ok=True)
    img=img.convert("RGBA")
    if out_path.lower().endswith(".png"): img.save(out_path,"PNG"); return
    w,h=img.size
    with open(out_path,"wb") as f: f.write(_dds_header(w,h)); f.write(img.tobytes("raw","RGBA"))

def bake_text(img,text,corner="br",scale=0.45,alpha=255):
    if not text: return img
    img=img.convert("RGBA"); w,h=img.size
    layer=Image.new("RGBA",img.size,(0,0,0,0)); d=ImageDraw.Draw(layer)
    target_h=int(h*scale); target_w=int(w*0.9)
    lo,hi=8,max(16,h*3); best=lo
    for _ in range(24):
        mid=(lo+hi)//2
        if mid==best: break
        bb=_font(mid).getbbox(text); gw,gh=bb[2]-bb[0],bb[3]-bb[1]
        if gh<=target_h and gw<=target_w: best=mid; lo=mid+1
        else: hi=mid-1
    size=best; font=_font(size); bbox=font.getbbox(text)
    tw,th=bbox[2]-bbox[0],bbox[3]-bbox[1]; pad=int(w*0.03)
    if corner=="br": x,y=w-tw-pad,h-th-pad
    elif corner=="bl": x,y=pad,h-th-pad
    elif corner=="tr": x,y=w-tw-pad,pad
    elif corner=="tl": x,y=pad,pad
    else: x,y=(w-tw)//2,(h-th)//2
    ox,oy=x-bbox[0],y-bbox[1]; sh=max(2,size//30)
    for dx,dy in ((sh,sh),(sh,0),(0,sh)):
        d.text((ox+dx,oy+dy),text,font=font,fill=(0,0,0,140))
    pp=max(3,size//8)
    pl=[x-pp,y-pp,x+tw+pp,y+th+pp]
    try: d.rounded_rectangle(pl,radius=max(2,pp//2),fill=(0,0,0,160))
    except: d.rectangle(pl,fill=(0,0,0,160))
    d.text((ox,oy),text,font=font,fill=(255,255,255,alpha))
    return Image.alpha_composite(img,layer)

# ---------------------------------------------------------------------------
# Auto-detect icons
# ---------------------------------------------------------------------------
def find_icons():
    for drive in "CDEFG":
        for sub in [r"Program Files (x86)\Steam",r"Program Files\Steam",
                    "Steam","SteamLibrary"]:
            p=os.path.join(drive+":\\",sub,"steamapps","common","AoE2DE",
                           "widgetui","textures","ingame")
            if os.path.isdir(p): return p
    return None

def find_mods_local():
    home=os.path.expanduser("~")
    hits=sorted(glob.glob(os.path.join(home,"Games","Age of Empires 2 DE","*","mods","local")))
    # skip dummy folders like "0", prefer real Steam ID (long numeric)
    for d in hits:
        steam_id=d.replace("\\","/").split("/")
        for part in steam_id:
            if part.isdigit() and len(part)>5:
                return d
    # fallback: any non-"0" folder
    for d in hits:
        if os.sep+"0"+os.sep not in d and "/0/" not in d:
            return d
    return hits[0] if hits else None

# ---------------------------------------------------------------------------
# Build
# ---------------------------------------------------------------------------
MOD_NAME="Hotkey Letters (personal)"

def build_mod(hkp_paths, icons_dir, out_dir, log=print):
    binds={}
    for p in hkp_paths:
        if p and os.path.isfile(p):
            binds.update(parse_hkp(p))
    ing=os.path.join(out_dir,"widgetui","textures","ingame")
    done=skipped=0
    for rel,hid in MAPPING.items():
        combo=binds.get(hid,"")
        if not combo: skipped+=1; continue
        src=os.path.join(icons_dir,rel)
        if not os.path.isfile(src):
            parent=os.path.join(icons_dir,os.path.dirname(rel))
            base=os.path.basename(rel).lower(); found=None
            if os.path.isdir(parent):
                for f in os.listdir(parent):
                    if f.lower()==base: found=os.path.join(parent,f); break
            if not found: skipped+=1; continue
            src=found
        try:
            img=read_image(src); img=bake_text(img,combo)
            write_baked(img,os.path.join(ing,rel)); done+=1
        except Exception as e:
            log("  skip %s (%s)"%(rel,e)); skipped+=1
    os.makedirs(out_dir,exist_ok=True)
    json.dump({"Author":"local","Title":MOD_NAME,
               "Description":"Hotkey letters baked from your profile.","IsUIMod":True},
              open(os.path.join(out_dir,"info.json"),"w"),indent=2)
    return done,skipped

# ---------------------------------------------------------------------------
# GUI
# ---------------------------------------------------------------------------
def run_gui():
    import tkinter as tk
    from tkinter import filedialog

    icons_dir = find_icons()
    mods_dir = find_mods_local()

    root = tk.Tk()
    root.title("AoE2 DE Hotkey Icon Baker")
    root.configure(bg="#0f0f1a")
    root.geometry("600x620")
    root.resizable(False, True)

    # -- colours --
    BG = "#0f0f1a"
    CARD = "#1a1a2e"
    ACCENT = "#8857A4"
    GREEN = "#2ecc71"
    RED = "#e74c3c"
    GREY = "#888"
    WHITE = "#eee"

    # -- title --
    tk.Label(root, text="AoE2 DE Hotkey Icon Baker", font=("Segoe UI", 20, "bold"),
             fg=WHITE, bg=BG).pack(pady=(20, 4))
    tk.Label(root, text="Bakes your hotkeys onto your in-game icons",
             font=("Segoe UI", 10), fg=GREY, bg=BG).pack()

    # -- step 1: load Base.hkp --
    f1 = tk.Frame(root, bg=CARD, highlightbackground="#333", highlightthickness=1)
    f1.pack(fill="x", padx=24, pady=(20, 8), ipady=10)

    tk.Label(f1, text="Step 1", font=("Segoe UI", 12, "bold"),
             fg=ACCENT, bg=CARD).pack(anchor="w", padx=14, pady=(8, 0))
    tk.Label(f1, text="Load your Base.hkp file", font=("Segoe UI", 11),
             fg=WHITE, bg=CARD).pack(anchor="w", padx=14)
    tk.Label(f1, text="Found in:  ...\\Age of Empires 2 DE\\<your id>\\profile\\<YourProfile>\\Base.hkp",
             font=("Consolas", 9), fg=GREY, bg=CARD, wraplength=540, justify="left"
             ).pack(anchor="w", padx=14, pady=(2, 6))

    status_var = tk.StringVar(value="No file loaded")
    status_label = tk.Label(f1, textvariable=status_var, font=("Segoe UI", 10, "bold"),
                            fg=GREY, bg=CARD)
    status_label.pack(anchor="w", padx=14)

    loaded_path = [None]

    def browse():
        p = filedialog.askopenfilename(
            title="Select Base.hkp",
            filetypes=[("HKP files", "*.hkp"), ("All files", "*.*")])
        if not p: return
        try:
            ok, count = validate_hkp(p)
            if ok:
                loaded_path[0] = p
                status_var.set("Correct file loaded  (%d hotkey slots found)" % count)
                status_label.configure(fg=GREEN)
                build_btn.configure(state="normal", bg=ACCENT)
            else:
                status_var.set("Incorrect file - does not look like a valid Base.hkp")
                status_label.configure(fg=RED)
        except Exception:
            status_var.set("Error reading file - not a valid .hkp")
            status_label.configure(fg=RED)

    tk.Button(f1, text="Browse for Base.hkp...", command=browse,
              bg="#2a2a4a", fg=WHITE, font=("Segoe UI", 10),
              activebackground="#3a3a5a", relief="flat", padx=12, pady=4
              ).pack(anchor="w", padx=14, pady=(4, 8))

    # -- step 2: icons (auto-detected) --
    f2 = tk.Frame(root, bg=CARD, highlightbackground="#333", highlightthickness=1)
    f2.pack(fill="x", padx=24, pady=8, ipady=10)

    tk.Label(f2, text="Step 2", font=("Segoe UI", 12, "bold"),
             fg=ACCENT, bg=CARD).pack(anchor="w", padx=14, pady=(8, 0))
    tk.Label(f2, text="Game icons", font=("Segoe UI", 11),
             fg=WHITE, bg=CARD).pack(anchor="w", padx=14)

    if icons_dir:
        tk.Label(f2, text="Auto-detected: " + icons_dir,
                 font=("Consolas", 9), fg=GREEN, bg=CARD, wraplength=540, justify="left"
                 ).pack(anchor="w", padx=14, pady=(2, 4))
    else:
        tk.Label(f2, text="Not found automatically",
                 font=("Segoe UI", 9), fg=RED, bg=CARD).pack(anchor="w", padx=14)
        def browse_icons():
            nonlocal icons_dir
            p = filedialog.askdirectory(title="Select the ingame icons folder")
            if p: icons_dir = p
        tk.Button(f2, text="Browse...", command=browse_icons,
                  bg="#2a2a4a", fg=WHITE, font=("Segoe UI", 10),
                  relief="flat").pack(anchor="w", padx=14, pady=(2, 8))

    # -- log area --
    log_frame = tk.Frame(root, bg=BG)
    log_frame.pack(fill="both", expand=True, padx=24, pady=(8, 4))
    log_text = tk.Text(log_frame, height=6, bg="#111", fg="#ccc",
                       font=("Consolas", 9), wrap="word", state="disabled",
                       relief="flat", borderwidth=0)
    log_text.pack(fill="both", expand=True)

    def log(msg):
        log_text.configure(state="normal")
        log_text.insert("end", msg + "\n")
        log_text.see("end")
        log_text.configure(state="disabled")
        root.update_idletasks()

    # -- build button --
    def go():
        if not loaded_path[0]:
            status_var.set("Please load Base.hkp first")
            status_label.configure(fg=RED)
            return
        if not icons_dir:
            log("Icons folder not set."); return

        out = os.path.join(mods_dir, MOD_NAME) if mods_dir else \
              os.path.join(os.path.dirname(os.path.abspath(__file__)), MOD_NAME)

        # Find both files: Base.hkp + the profile .hkp next to it
        base = loaded_path[0]
        profile_dir = os.path.dirname(os.path.dirname(base))  # up from <Profile>/Base.hkp
        profile_name = os.path.basename(os.path.dirname(base))  # folder name = profile name
        profile_hkp = os.path.join(profile_dir, profile_name + ".hkp")
        hkp_paths = [base]
        if os.path.isfile(profile_hkp):
            hkp_paths.append(profile_hkp)
            log("Base.hkp: " + base)
            log("Profile: " + profile_hkp)
        else:
            log("Reading hotkeys from: " + base)
            log("(Profile .hkp not found next to Base.hkp, using Base only)")
        log("Icons: " + icons_dir)
        log("Output: " + out)
        log("Baking %d mapped icons..." % len(MAPPING))
        build_btn.configure(state="disabled", bg="#555")
        root.update_idletasks()

        try:
            done, skipped = build_mod(hkp_paths, icons_dir, out, log)
            log("\nBaked %d icons. Skipped %d (unbound keys)." % (done, skipped))
            log("Enable '%s' in the in-game Mods menu." % MOD_NAME)
            build_btn.configure(text="Done - You may exit this application",
                                bg=GREEN, fg="#111", state="disabled",
                                font=("Segoe UI", 13, "bold"))
        except Exception:
            log("\nError:\n" + traceback.format_exc())
            build_btn.configure(state="normal", bg=ACCENT)

    build_btn = tk.Button(root, text="Build Mod", command=go,
                          bg="#555", fg=WHITE, disabledforeground="#888",
                          font=("Segoe UI", 13, "bold"),
                          activebackground="#9967b4", relief="flat",
                          padx=24, pady=8, state="disabled")
    build_btn.pack(pady=(4, 20))

    root.mainloop()

# ---------------------------------------------------------------------------
if __name__ == "__main__":
    try:
        import tkinter
        run_gui()
    except ImportError:
        input("tkinter not available. Install Python with tk support.\nPress Enter to exit.")
