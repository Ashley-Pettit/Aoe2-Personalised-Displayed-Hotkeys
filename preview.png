#!/usr/bin/env python3
"""
AoE2 DE Hotkey Icon Baker - Standalone GUI
Double-click to run. Builds as .exe with:
  pip install pyinstaller && python -m PyInstaller --onefile --noconsole aoe2_hotkey_baker_standalone.py
"""

import os, sys, glob, zlib, struct, csv, json, io, traceback

